{
  "name": "make-a-decision-for-us",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "eslint": "^9.8.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {},
  "private": true,
  "workspaces": [
    "front",
    "back"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "frontdev": "bun run --cwd front dev",
    "backdev": "bun run --cwd back dev",
    "dev": "concurrently \"bun run --cwd back dev\" \"bun run --cwd front dev\"",
    "build": "bun run --cwd front build",
    "start": "bun run --cwd back start",
    "go": "bun run build && bun run start",
    "lint": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.47.0",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "react-icons": "^5.6.0"
  }
}
